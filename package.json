{
  "name": "ereader-book-transfer",
  "version": "1.0.0",
  "description": "Bluetooth MCU e-reader book transfer system",
  "main": "server/index.js",
  "engines": {
    "node": ">=20.9.0 <24.0.0"
  },
  "scripts": {
    "start": "node server/index.js",
    "build": "npm --prefix frontend install && cd frontend && rm -rf out && npx next build && rm -rf ../public/* && cp -r out/* ../public/",
    "dev": "node --watch server/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "11.7.0",
    "express": "^4.21.0",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.1",
    "sharp": "0.33.5",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^4.1.7"
  }
}
